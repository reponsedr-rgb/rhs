                                    <li class="mb-2"><i class="fas fa-star text-warning me-2"></i>Character development</li>
                                    <li><i class="fas fa-star text-warning me-2"></i>Extracurricular activities</li>
                                </ul>
                            </div>
                        </div>

                        <!-- Apply Button -->
                        <div class="card border-0 rounded-3 shadow-sm mb-4 bg-primary text-white">
                            <div class="card-body text-center">
