                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Key Features Card -->
                        <div class="card border-0 rounded-3 shadow-sm mb-4">
                            <div class="card-body">
                                <h5 class="card-title mb-3">Key Features</h5>
                                <ul class="list-unstyled small">
                                    <li class="mb-2"><i class="fas fa-star text-warning me-2"></i>Comprehensive curriculum</li>
